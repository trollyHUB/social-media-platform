        {
          "name": "PUT - Update Post",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": \"tolegen\",\n  \"content\": \"Обновлённый текст поста через PUT запрос\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "1"]
            },
            "description": "Обновить пост по ID."
          },
          "response": []
        },
        {
          "name": "DELETE - Delete Post",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "1"]
            },
            "description": "Удалить свой пост по ID."
          },
          "response": []
