# =====================================================
# NEXIS Connect — .gitignore
# =====================================================

# ==================== JAVA / MAVEN ====================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# ==================== FRONTEND ====================
frontend/node/
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/

# ==================== IDE ====================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# ==================== OS ====================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~

# ==================== СЕКРЕТЫ ====================
# Никогда не коммитить файлы с паролями!
src/main/resources/application.properties
application-local.properties
application-prod.properties
.env
.env.local
.env.production
*.pem
*.key

# ==================== ЛОГИ ====================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== БИНАРНИКИ ====================
bun.lockb

# ==================== СТАРАЯ ДОКУМЕНТАЦИЯ ====================
# Перенесена в docs/archive/
DOCS GENERAL/

# ==================== ВНУТРЕННЯЯ ДОКУМЕНТАЦИЯ ====================
# Не публиковать! Личные заметки, УМКД, AI инструкции, идеи
docs/
КАК-ЗАПУСКАТЬ.md
database_init.sql

# ==================== РАЗНОЕ ====================
.kotlin
build/
!**/src/main/**/build/
!**/src/test/**/build/
